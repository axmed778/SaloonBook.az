# ----------------------------------------------------------------------------
# SalonBook.az environment
# Copy to .env and fill in. Never commit .env.
# ----------------------------------------------------------------------------

# --- Database (PostgreSQL) ---
# Railway/local. The app expects timestamptz; all app logic stores UTC.
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/salonbook?schema=public"

# --- Redis (queue + cache + locks) ---
REDIS_URL="redis://localhost:6379"

# --- Auth (Clerk) ---
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=""
CLERK_SECRET_KEY=""
CLERK_WEBHOOK_SECRET=""

# --- WhatsApp (Meta Cloud API) ---
# Leave WHATSAPP_TOKEN empty in dev to run the notification sender in sandbox
# mode (messages are logged, not sent).
WHATSAPP_TOKEN=""
WHATSAPP_PHONE_NUMBER_ID=""
WHATSAPP_VERIFY_TOKEN="change-me-dev-verify-token"
WHATSAPP_APP_SECRET=""

# --- Cloudflare R2 (file storage) ---
R2_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET="salonbook"

# --- App ---
# Used for building public booking links: {APP_URL}/{slug}
APP_URL="http://localhost:3000"
NODE_ENV="development"
